MONGO_URL="mongodb://localhost:27017"
DB_NAME="procurement_analytics"
CORS_ORIGINS="*"

# JWT
JWT_SECRET="change_this_in_production_procurement_maha_2026"
JWT_ALGORITHM="HS256"
JWT_EXPIRES_MINUTES=720

# Business thresholds
HIGH_VALUE_THRESHOLD_CR=10

# Seed data on first boot
SEED_DATA_ON_STARTUP=true
SEED_EXCEL_PATH="./uploaded_data/abcd.xlsx"

# Scheduler
ENABLE_SCHEDULER=true
SCHEDULER_INTERVAL_MINUTES=60

# KPI alert thresholds
ALERT_PAYMENT_COMPLETION_MIN=60
ALERT_BACKLOG_PCT_MAX=25
ALERT_RISK_EXPOSURE_MAX=30
ALERT_PO_CONVERSION_MIN=50

# Escalation (in days)
ESCALATION_L1_DAYS=7
ESCALATION_L2_DAYS=14
ESCALATION_L5_DAYS=30

# SMTP - leave empty for mock/log-only mode
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="procurement-alerts@maha.gov.in"
SMTP_TLS=true
